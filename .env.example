# Copie para .env e preencha os valores locais.
# Nunca commite o arquivo .env.

# MySQL / MariaDB (obrigatório para API e seed)
DATABASE_URL=mysql://afu:senha@127.0.0.1:3306/afu_mobile

# JWT (obrigatório para login)
JWT_SECRET=troque_por_uma_chave_longa_e_aleatoria

# Identificador do app (opcional em dev local)
VITE_APP_ID=afu-mobile-local-dev

# API base para dispositivo físico / dev client (use o IP da sua máquina na LAN)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:3000

# Opcional — OAuth Manus / e-mail
# OAUTH_SERVER_URL=
# EXPO_PUBLIC_OAUTH_SERVER_URL=
# EXPO_PUBLIC_OAUTH_PORTAL_URL=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
