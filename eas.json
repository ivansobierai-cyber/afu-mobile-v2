{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://afu-mobile-v2-production.up.railway.app",
        "EXPO_PUBLIC_SHOW_DEMO_LOGIN": "1"
      }
    },
    "preview-simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://192.168.1.5:3000",
        "EXPO_PUBLIC_SHOW_DEMO_LOGIN": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.afuagro.com.br",
        "EXPO_PUBLIC_SHOW_DEMO_LOGIN": "0"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "appleId": "seu-apple-id@email.com",
        "ascAppId": "SUBSTITUIR_PELO_APP_STORE_CONNECT_ID"
      }
    }
  }
}
