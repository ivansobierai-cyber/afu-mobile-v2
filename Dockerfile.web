FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG EXPO_PUBLIC_API_BASE_URL=
ARG EXPO_PUBLIC_SHOW_DEMO_LOGIN=1
ENV EXPO_PUBLIC_API_BASE_URL=$EXPO_PUBLIC_API_BASE_URL
ENV EXPO_PUBLIC_SHOW_DEMO_LOGIN=$EXPO_PUBLIC_SHOW_DEMO_LOGIN

RUN node scripts/ensure-nativewind-cache.mjs \
  && npx expo export --platform web \
  && node scripts/prepare-web-dist.mjs

FROM nginx:1.27-alpine
COPY deploy/nginx.oci.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
