{
  "name": "afu-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "AFU Agro — Planta Saudável (Expo + tRPC + MySQL)",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port 8081",
    "dev:web:tunnel": "cross-env EXPO_PUBLIC_API_BASE_URL=https://afu-mobile-v2-production.up.railway.app EXPO_PUBLIC_SHOW_DEMO_LOGIN=1 EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --tunnel",
    "build:web": "node scripts/ensure-nativewind-cache.mjs && expo export --platform web",
    "build:web:preview": "node scripts/ensure-nativewind-cache.mjs && cross-env EXPO_PUBLIC_API_BASE_URL=https://afu-mobile-v2-production.up.railway.app EXPO_PUBLIC_SHOW_DEMO_LOGIN=1 expo export --platform web",
    "prepare:web-dist": "node scripts/prepare-web-dist.mjs",
    "deploy:web": "npm run build:web:preview && npm run prepare:web-dist && npx vercel deploy dist --prod --yes --project afu-mobile-web",
    "deploy:oci": "bash scripts/oci-deploy.sh",
    "agents:archive-stale": "node scripts/archive-stale-agents.mjs",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:security:etapa10": "tsx scripts/run-etapa10-security.ts",
    "test:propriedades:etapa2": "tsx scripts/run-propriedades-etapa2-aceitacao.ts",
    "check:tenant-queries": "node scripts/check-tenant-queries.mjs",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate": "drizzle-kit migrate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:reset": "docker compose down -v && docker compose up -d",
    "seed": "tsx scripts/seed.ts",
    "seed:agronomico": "tsx scripts/seed-agronomico.ts",
    "seed:expansao": "tsx scripts/seed-expansao.ts",
    "seed:lab-economia": "tsx scripts/seed-lab-economia.ts",
    "seed:geo-iot": "tsx scripts/seed-geo-iot.ts",
    "seed:noc-arquitetura": "tsx scripts/seed-noc-arquitetura.ts",
    "seed:banco-expansao": "tsx scripts/seed-banco-expansao.ts",
    "seed:marketplace": "tsx scripts/seed-marketplace.ts",
    "seed:comprador": "tsx scripts/seed-comprador.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "db:safras:apply": "tsx scripts/apply-0020-safras.ts",
    "db:safras:backfill": "tsx scripts/backfill-safras.ts",
    "db:archive:apply": "tsx scripts/apply-0021-property-archive.ts",
    "db:tarefas-responsavel:apply": "tsx scripts/apply-0022-tarefas-responsavel.ts",
    "db:maquinas:apply": "tsx scripts/apply-0023-maquinas.ts",
    "db:estoque:apply": "tsx scripts/apply-0024-estoque-inteligente.ts",
    "db:centros-custo:apply": "tsx scripts/apply-0025-centros-custo.ts",
    "db:financeiro:apply": "tsx scripts/apply-0026-financeiro-lancamentos.ts",
    "db:sync-ai:apply": "tsx scripts/apply-0018-0019-sync-ai.ts",
    "backfill:organizations": "tsx scripts/backfill-organizations.ts",
    "backfill:organization-id": "tsx scripts/backfill-organization-id.ts",
    "weather:alerts": "tsx scripts/run-weather-alerts.ts",
    "eas:android:dev": "eas build --platform android --profile development",
    "eas:android:preview": "eas build --platform android --profile preview",
    "eas:android:apk": "eas build --platform android --profile apk",
    "eas:android:prod": "eas build --platform android --profile production",
    "eas:ios:preview": "eas build --platform ios --profile preview",
    "eas:ios:preview:simulator": "eas build --platform ios --profile preview-simulator",
    "eas:ios:prod": "eas build --platform ios --profile production",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.8",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "11.7.2",
    "@trpc/react-query": "11.7.2",
    "@trpc/server": "11.7.2",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.13.2",
    "babel-preset-expo": "~54.0.10",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.12",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "express": "^4.22.1",
    "jose": "6.1.0",
    "mysql2": "^3.16.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  }
}
